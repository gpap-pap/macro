          "_name": "news09",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"news09 startm5\" group=\"News\">\n  <mbr-parameters>\n    <header>Size</header>\n    <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n    <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"6\">\n    <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"6\">\n    <input type=\"range\" name=\"textWidth\" title=\"Width\" min=\"4\" max=\"12\" value=\"8\" step=\"1\">\n    <header>Show/Hide</header>\n    <input type=\"checkbox\" title=\"Title\" name=\"showMainTitle\" checked>\n    <input type=\"checkbox\" title=\"Subtitle\" name=\"showMainSubtitle\">\n    <header>Card</header>\n    <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n    <input type=\"checkbox\" title=\"Date\" name=\"showDate\">\n    <input type=\"checkbox\" title=\"Time\" name=\"showTime\">\n    <input type=\"checkbox\" title=\"Location\" name=\"showLocation\" checked>\n    <input type=\"checkbox\" title=\"Price\" name=\"showPrice\">\n    <input type=\"checkbox\" title=\"Description\" name=\"showDescription\" checked>\n    <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n    <input type=\"color\" title=\"Card BG\" name=\"cardbg\" value=\"#edefeb\" selected>\n    <input type=\"color\" title=\"Icon Color\" name=\"iconColor\" value=\"#000000\" selected>\n    <header>Background</header>\n    <input type=\"color\" title=\"Color\" name=\"bgColor\" value=\"#0b132b\">\n  </mbr-parameters>\n  <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n    <div class=\"col-12 mb-5 content-head\" mbr-if=\"showMainTitle || showMainSubtitle\">\n      <h3 class=\"mbr-section-title mbr-fonts-style align-center mb-0\" mbr-theme-style=\"display-5\" mbr-if=\"showMainTitle\" data-app-selector=\".mbr-section-title\"><b>&nbsp;Athens Macroeconomics Workshop 2026</b></h3>\n      <h5 class=\"mbr-section-subtitle mbr-fonts-style align-center mb-0 mt-4\" mbr-theme-style=\"display-7\" mbr-if=\"showMainSubtitle\" data-app-selector=\".mbr-section-subtitle\">\n        Lorem ipsum dolor sit amet, consectetur adipiscing elit.\n      </h5>\n    </div>\n    <div class=\"row justify-content-center \">\n      <div class=\" col-12 col-lg-{{textWidth}}\">\n        <div class=\"item features-without-image col-12 active\">\n          <div class=\"item-wrapper\">\n            <h5 class=\"mbr-card-title mbr-fonts-style mt-0 mb-3\" mbr-if=\"showTitle\" data-app-selector=\".mbr-card-title\" mbr-theme-style=\"display-5\"><b>Thursday, 10th, September 2026</b></h5>\n            <div class=\"details\">\n              <div class=\"details-item\" mbr-theme-style=\"display-7\" mbr-if=\"showDate\">\n                <span mbr-icon class=\"mbr-iconfont details-icon mobi-mbri-arrow-next mobi-mbri\" style=\"color: rgb(12, 44, 104); fill: rgb(12, 44, 104);\"></span>\n                <p class=\"mbr-tag mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-tag, .tags-wrapper\"></p>\n              </div>\n              <div class=\"details-item\" mbr-theme-style=\"display-7\" mbr-if=\"showTime\">\n                <span mbr-icon class=\"mbr-iconfont details-icon mobi-mbri-timer mobi-mbri\" style=\"color: rgb(255, 255, 255); fill: rgb(255, 255, 255);\"></span>\n                <p class=\"mbr-tag mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-tag, .tags-wrapper\"></p>\n              </div>\n            </div>\n            <div class=\"details\" mbr-if=\"showLocation\">\n              <div class=\"details-item\" mbr-theme-style=\"display-7\">\n                <span mbr-icon class=\"mbr-iconfont mobi-mbri-map-pin mobi-mbri details-icon\"></span>\n                <p class=\"mbr-tag mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-tag, .tags-wrapper\"><b> <a href=\"https://maps.app.goo.gl/rqjV235j9AEwiDKp7\" class=\"text-primary\" target=\"_blank\">Troias Building Athens University of Economics and Business, Troias 2, Athens.</a></b><b><br></b><br></p>\n              </div>\n            </div>\n            <div class=\"details\" mbr-if=\"showPrice\">\n              <div class=\"details-item\" mbr-theme-style=\"display-7\">\n                <span mbr-icon class=\"mbr-iconfont details-icon mobi-mbri-cash mobi-mbri\" style=\"color: rgb(255, 255, 255); fill: rgb(255, 255, 255);\"></span>\n                <p class=\"mbr-tag mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-tag, .tags-wrapper\"></p>\n              </div>\n            </div>\n            <h6 class=\"mbr-card-subtitle mbr-fonts-style mt-0 mb-3\" mbr-if=\"showDescription\" data-app-selector=\".mbr-card-subtitle\" mbr-theme-style=\"display-4\"><b>• 9:00-9:30</b><b><br></b>\t                       Registration and welcome<br><br><b>Session A:</b><b><br>• 9:30-10:15</b><b><br></b>\t<a href=\"https://www.birmingham.ac.uk/staff/profiles/business/rossi-raffaele\" class=\"text-primary\" target=\"_blank\">Raffaele Rossi</a> (University of Birmingham) “The Effects of Bad Health in Frictional Labour Market” <br>joint with <a href=\"https://www.birmingham.ac.uk/staff/profiles/business/di-nola-alessandro\" class=\"text-primary\" target=\"_blank\">Alessandro Di Nola</a> (University of Birmingham) and <a href=\"https://profiles.cardiff.ac.uk/staff/wangh142\" class=\"text-primary\" target=\"_blank\">Haomin Wang</a> (Cardiff University)\n<div>\n</div><div><b>• 10:15-11:00</b></div><div>\t<a href=\"https://www.brigittehochmuth.net/\" class=\"text-primary\" target=\"_blank\">Brigitte Hochmuth</a> (University of Copenhagen and CEPR) “Fiscal Policy under Labor Shortages” </div><div>joint&nbsp;<span style=\"font-size: 1rem;\">with <a href=\"https://gregorboehl.com/\" class=\"text-primary\" target=\"_blank\">Gregor Boehl</a> (University of Magdeburg)</span></div><div><b>• 11:00-11:30</b></div><div>\t                                    Coffee break\n</div><div><b>• 11:30-12:30</b></div><div><b>\tKeynote Talk:</b> <a href=\"https://sites.google.com/site/monacellitommaso/\" class=\"text-primary\" target=\"_blank\">Tommaso Monacelli</a>\n</div><div>(Bocconi University, IGIER and CEPR)\n</div><div>“Supply Chain Uncertainty, Energy Prices and Inflation”</div><div><span style=\"font-size: 1rem;\">joint&nbsp;</span><span style=\"font-size: 1rem;\">with <a href=\"https://www.qmul.ac.uk/sbm/staff/academic/profiles/merendinoa.html\" class=\"text-primary\" target=\"_blank\">A. Merendino</a> (ECB and Bocconi University)</span><br></div><br><div><b>Session B:</b></div><div>•<b>12:30-13:15</b></div><div>\t<a href=\"https://sites.google.com/view/annarogantini/home\" class=\"text-primary\" target=\"_blank\">Anna Rogantini Picco</a> (ECB and CEPR) “Fiscal threats to price stability when households are not Ricardian” joint with <a href=\"https://www.stephaneduprazecon.com/\" class=\"text-primary\" target=\"_blank\">Stephane Dupraz</a> (Banque de France)\n</div><div>•<b>13:15-14:00</b>\t</div><div><a href=\"https://www.hannahmseidl.com/\" class=\"text-primary\" target=\"_blank\">Hannah Seidl</a> (DIW Berlin) “Sectoral Spending, Household Heterogeneity, and Fiscal Multipliers” </div><div>joint with <a href=\"https://www.diw.de/sixcms/detail.php?id=diw_01.c.879413.en\" class=\"text-primary\" target=\"_blank\">Alina Ermolaeva</a> (DIW Berlin)\n</div><div>•<b>14:00-15:00</b></div><div>\tLunch break</div><br><div><b>Session C:</b></div><div>•<b>15:00-15:45</b></div><div><a href=\"https://www.elisabethproehl.com/\" class=\"text-primary\" target=\"_blank\">Elisabeth Proehl </a>(University of Amsterdam) “A Global Solution Method for HACT Models with Aggregate Risk” joint with  <a href=\"https://www.niklasbonnmann.com/\" class=\"text-primary\" target=\"_blank\">Niklas Bonnmann</a> (Free University Amsterdam)\n</div><div>•<b>15:45-16:30</b></div><div>\t<a href=\"https://sites.google.com/site/romanospriftis/home\" class=\"text-primary\" target=\"_blank\">Romanos Priftis</a> (European Central Bank) “Debt Maturity and Government Spending Multipliers” joint with <a href=\"https://ghomimorteza.github.io/index/\" class=\"text-primary\" target=\"_blank\">Morteza Ghomi</a> (Banco de Espana),<a href=\"https://mankart.net/\" class=\"text-primary\" target=\"_blank\"> Jochen Mankart</a> (Bundesbank/National Bank of Slovakia),<a href=\"https://sites.google.com/site/rigasoikonomou/home\" class=\"text-primary\" target=\"_blank\"> Rigas Oikonomou</a> (Universite Catholiqe&nbsp;de Louvain)\n</div><div>•<b>19:00</b></div><div>Dinner</div><div><b>\n</b></div><div><b>\n</b></div><div></div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\t\n</div><div>\n</div></h6>\n            <div mbr-buttons mbr-theme-style=\"display-7\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\"><a class=\"btn btn-primary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">Learn more</a></div>\n          </div>\n        </div>\n        <div class=\"item features-without-image col-12\">\n          <div class=\"item-wrapper\">\n            <h5 class=\"mbr-card-title mbr-fonts-style mt-0 mb-3\" mbr-if=\"showTitle\" data-app-selector=\".mbr-card-title\" mbr-theme-style=\"display-5\"><b>Thursday, 11th, September 2026</b></h5>\n            <div class=\"details\">\n              <div class=\"details-item\" mbr-theme-style=\"display-7\" mbr-if=\"showDate\">\n                <span mbr-icon class=\"mbr-iconfont mobi-mbri-calendar mobi-mbri details-icon\"></span>\n                <p class=\"mbr-tag mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-tag, .tags-wrapper\">November 25, 2023<br></p>\n              </div>\n             <div class=\"details-item\" mbr-theme-style=\"display-7\" mbr-if=\"showTime\">\n                <span mbr-icon class=\"mbr-iconfont mobi-mbri-timer mobi-mbri details-icon\"></span>\n                <p class=\"mbr-tag mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-tag, .tags-wrapper\">2:00 PM - 4:00 PM<br></p>\n              </div>\n            </div>\n            <div class=\"details\" mbr-if=\"showLocation\">\n              <div class=\"details-item\" mbr-theme-style=\"display-7\">\n                <span mbr-icon class=\"mbr-iconfont mobi-mbri-map-pin mobi-mbri details-icon\"></span>\n                <p class=\"mbr-tag mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-tag, .tags-wrapper\"><b><a href=\"https://maps.app.goo.gl/rqjV235j9AEwiDKp7\" class=\"text-primary\" target=\"_blank\">Troias Building Athens University of Economics and Business, Troias 2, Athens.</a></b><br></p>\n              </div>\n            </div>\n            <div class=\"details\" mbr-if=\"showPrice\">\n              <div class=\"details-item\" mbr-theme-style=\"display-7\">\n                <span mbr-icon class=\"mbr-iconfont details-icon mobi-mbri-cash mobi-mbri\"></span>\n                <p class=\"mbr-tag mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-tag, .tags-wrapper\">$55, or included in our membership fee<br></p>\n              </div>\n            </div>\n            <h6 class=\"mbr-card-subtitle mbr-fonts-style mt-0 mb-3\" mbr-if=\"showDescription\" data-app-selector=\".mbr-card-subtitle\" mbr-theme-style=\"display-4\"><b>Session A:\n</b><div>•<b>10:00-10:45</b>\t</div><div><a href=\"https://sites.google.com/site/anafigueiredovds/home\" class=\"text-primary\" target=\"_blank\">Ana Gomes Figueiredo</a> (Vrije Universiteit Amsterdam) “Self-Insurance in Turbulent Labor Markets” joint with <a href=\"https://www.isaacbaley.com/\" class=\"text-primary\" target=\"_blank\">Isaac Baley </a>(UPF, CREI, BSE, CEPR), <a href=\"https://cristianomantovani.github.io/\" class=\"text-primary\" target=\"_blank\">Cristiano Mantovani</a> (U of Melbourne), Ali Sepahsalari (U of Bristol)\n</div><div><b>•10:45-11:30</b></div><div>\t<a href=\"https://sites.google.com/view/andrichassamboulli/home\" class=\"text-primary\" target=\"_blank\">Andri Chassampouli</a> (University of Cyprus) “The First Precarious Step: Entry Jobs and Labor Market Prospects for New Entrants” joint with <a href=\"https://sites.google.com/view/ismaelgalvez/home\" class=\"text-primary\" target=\"_blank\">Ismael Galvez Iniesta</a>, <a href=\"https://ageromichalos.ucdavis.edu/\" class=\"text-primary\" target=\"_blank\">Thanasis Geormichalos</a>, <a href=\"https://sites.google.com/site/ioanniskospentaris/\" class=\"text-primary\" target=\"_blank\">Ioannis Kospentaris</a>\n</div><div>•<b>11:30-12:00</b></div><div>\t                                             Coffee break\n</div><div>•<b>12:00-13:00</b></div><div><span style=\"font-size: 1rem;\"><b>Keynote Talk: </b><a href=\"https://www.mathiastrabandt.com/\" class=\"text-primary\" target=\"_blank\">Mathias Trabandt</a></span></div><div>(Goethe University Frankfurt)\n</div><div>“Monetary Policy and Inflation Scares”\n</div><div>joint with <a href=\"https://www.imf.org/en/blogs/authors/christopher%20erceg\" class=\"text-primary\" target=\"_blank\">C. Erceg </a>(IMF), <a href=\"https://scholar.google.nl/citations?user=Sh7kUYgAAAAJ&hl=nl\" class=\"text-primary\" target=\"_blank\">J. Linde</a> (IMF and CEPR)\n</div><div><b>•13:00-13:45\t</b></div><div>Lunch break</div><br><div><b>Session B:\n</b></div><div>•<b>13:45-14:30</b></div><div>\t<a href=\"https://sites.google.com/site/pgvarth/home\" class=\"text-primary\" target=\"_blank\">Petros Varthalitis</a> (Athens University of Economics and Business) “Global intangible capital and inequality: A two country heterogeneous agents framework” joint with <a href=\"https://www.slazarakis.com/\" class=\"text-primary\" target=\"_blank\">Spyros Lazarakis</a>.\n</div><div>•<b>14:30-15:15</b></div><div><span style=\"font-size: 1rem;\"><a href=\"https://sites.google.com/site/dimitrispapageorgioupage/\" class=\"text-primary\" target=\"_blank\">Dimitris Papageorgiou</a> (Bank of Greece) “To be or not to be in the Banking Union” joint with <a href=\"https://harrisdellas.net/\" class=\"text-primary\" target=\"_blank\">Harris Dellas</a>.</span></div><div>•<b>15:15-16:00</b>\t</div><div>Lunch break</div><br><div><b>Session C: \n</b></div><div><b>•16:00-16:45</b></div><div>\t<a href=\"https://andrejmijakovic.github.io/\" class=\"text-primary\" target=\"_blank\">Andrej Mijakovic</a> (University of Mannheim) “Income Inequality and the Rise of Risky Capital”\n</div><div><b>•16:45-17:30</b>\t</div><div><a href=\"https://sites.google.com/view/alina-bartscher\" class=\"text-primary\" target=\"_blank\">Alina Bartscher</a> (Frankfurt School) “Causal Effects of Interest Rate Beliefs on Firm Decisions and their Aggregate Implications” joint with  <a href=\"https://sites.google.com/site/georgduernecker/home\" class=\"text-primary\" target=\"_blank\">Georg Duernecker</a>, <a href=\"https://sites.google.com/view/johannesgoensch\" class=\"text-primary\" target=\"_blank\">Johannes Goensch</a>, and <a href=\"https://sites.google.com/view/nilswehrhoefer/nils-wehrh%C3%B6fer\" class=\"text-primary\" target=\"_blank\">Nils Wehrhöfer</a>\n</div><div><b>•17:30</b></div><div>\tFarewell Drinks</div><div><br></div><div><b>End of workshop&nbsp;</b></div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div></h6>\n            <div mbr-buttons mbr-theme-style=\"display-7\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\"><a class=\"btn btn-primary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">Learn more</a></div>\n          </div>\n        </div>\n\n      </div>\n    </div>\n  </div>\n</section>",
          "_cid": "vo2wAcWrtu",
          "_anchor": "news09-9",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = \"color\")": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = \"image\")": {
              "background-image": "url(@bg-value)",
              "& when (@overlay)": {
                ".mbr-overlay": {
                  "background": "@overlayColor",
                  "opacity": "@overlayOpacity"
                }
              }
            },
            ".item-subtitle": {
              "line-height": "1.2",
              "color": "#000000",
              "text-align": "center"
            },
            "img, .item-img": {
              "width": "100%",
              "& when (@autoSize)": {
                "height": "100%",
                "object-fit": "cover",
                "& when (@showCardTitle)": {
                  "height": "(@imageHeight * 100px)",
                  "object-fit": "cover"
                },
                "& when (@showCardSubtitle)": {
                  "height": "(@imageHeight * 100px)",
                  "object-fit": "cover"
                },
                "& when (@showText)": {
                  "height": "(@imageHeight * 100px)",
                  "object-fit": "cover"
                },
                "& when (@showButtons)": {
                  "height": "(@imageHeight * 100px)",
                  "object-fit": "cover"
                }
              }
            },
            ".item:focus, span:focus": {
              "outline": "none"
            },
            ".item": {
              "margin-bottom": "2rem",
              "@media (max-width: 767px)": {
                "margin-bottom": "1rem"
              }
            },
            "& when not (@spacing)": {
              ".row": {
                "margin-left": "0",
                "margin-right": "0"
              },
              ".item": {
                "padding": "0",
                "margin": "0"
              }
            },
            ".item-wrapper": {
              "position": "relative",
              "border-radius": "4px",
              "display": "flex",
              "flex-flow": "column nowrap"
            },
            ".mbr-section-btn": {
              "margin-top": "auto !important"
            },
            ".mbr-section-title": {
              "color": "#edefeb"
            },
            ".mbr-text, .mbr-section-btn": {
              "color": "#edefeb",
              "text-align": "center"
            },
            ".item-title": {
              "color": "#edefeb",
              "text-align": "center"
            },
            ".content-head": {
              "max-width": "800px"
            }
          },
          "_name": "people03",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"people03\" group=\"People\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n\t<mbr-parameters>\n\t\t<header>Size</header>\n\t\t<input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n\t\t<input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"6\">\n\t\t<input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"6\">\n\t\t<select title=\"Columns\" name=\"cardsWidth\">\n\t\t\t<option value=\"12\">1</option>\n\t\t\t<option value=\"6\">2</option>\n\t\t\t<option value=\"4\" selected>3</option>\n\t\t\t<option value=\"3\">4</option>\n\t\t</select>\n\t\t<header>Show/Hide</header>\n\t\t<input type=\"checkbox\" name=\"showTitle\" title=\"Title\" checked>\n\t\t<input type=\"checkbox\" name=\"showSubtitle\" title=\"Subtitle\">\n\t\t<header>Cards</header>\n\t\t<input type=\"checkbox\" name=\"autoSize\" title=\"Auto Size\" checked>\n\t\t<input type=\"range\" name=\"imageHeight\" title=\"Height\" min=\"1\" max=\"5\" step=\"1\" value=\"4\" condition=\"autoSize && !(showButtons==false && showCardSubtitle==false && showCardTitle==false && showText==false)\">\n\t\t<input type=\"checkbox\" title=\"Spacing\" name=\"spacing\" checked>\n\t\t<input type=\"checkbox\" name=\"showCardTitle\" title=\"Name\" checked>\n\t\t<input type=\"checkbox\" name=\"showCardSubtitle\" title=\"Position\">\n\t\t<input type=\"checkbox\" name=\"showText\" title=\"Text\" checked>\n\t\t<input type=\"checkbox\" name=\"showButtons\" title=\"Buttons\">\n\t\t<header>Background</header>\n\t\t<fieldset type=\"background\" parallax name=\"bg\" required>\n\t\t\t<input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n\t\t\t<input type=\"color\" title=\"Color\" value=\"#0b132b\" selected>\n\t\t</fieldset>\n\t\t<input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n\t\t<input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#edefeb\" condition=\"overlay && bg.type == 'image'\">\n\t\t<input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.6\" condition=\"overlay && bg.type == 'image'\">\n\t</mbr-parameters>\n\t<div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\"></div>\n\t<div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n\t\t<div class=\"row justify-content-center\">\n\t\t\t<div class=\"col-12 content-head\">\n\t\t\t\t<div class=\"mbr-section-head mb-5\" mbr-if=\"showTitle || showSubtitle\">\n\t\t\t\t\t<h4 class=\"mbr-section-title mbr-fonts-style align-center mb-0\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\">\n\t\t\t\t\t\t<b>Organizers</b></h4>\n\t\t\t\t\t<h5 class=\"mbr-section-subtitle mbr-fonts-style align-center mt-4\" mbr-theme-style=\"display-7\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\">\n\t\t\t\t\t\tTo add more cards, hover on a card and click 'Add items'\n\t\t\t\t\t</h5>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t\t<div class=\"row\">\n\t\t\t<div class=\"item features-image col-12 col-md-6 col-lg-{{cardsWidth}} active\">\n\t\t\t\t<div class=\"item-wrapper\">\n\t\t\t\t\t<div class=\"item-img mb-3\">\n\t\t\t\t\t\t<a href=\"https://sites.google.com/site/ioanniskospentaris/\" target=\"_blank\"><img src=\"@PROJECT_PATH@/assets/images/unnamed-1-320x480.jpg\" alt title data-slide-to=\"0\" data-bs-slide-to=\"0\"></a>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"item-content align-left\" mbr-if=\"showCardTitle || showCardSubtitle || showText || showButtons\">\n\t\t\t\t\t\t<h5 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".item-title\" mbr-if=\"showCardTitle\"><b>Ioannis Kospentaris</b></h5>\n\t\t\t\t\t\t<h6 class=\"item-subtitle mbr-fonts-style mb-3\" mbr-theme-style=\"display-7\" data-app-selector=\".item-subtitle\" mbr-if=\"showCardSubtitle\">Lead Developer</h6>\n\t\t\t\t\t\t<p class=\"mbr-text mbr-fonts-style mt-3\" mbr-if=\"showText\" mbr-theme-style=\"display-4\" data-app-selector=\".mbr-text, .mbr-section-btn\">(Athens University of Economics and Business)<br>\n\t\t\t\t\t\t</p>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"mbr-section-btn item-footer mt-2\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd\" mbr-buttons mbr-theme-style=\"display-7\">\n\t\t\t\t\t\t<a href class=\"btn item-btn btn-primary\" data-app-placeholder=\"Type Text\">Contact</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div><div class=\"item features-image col-12 col-md-6 col-lg-{{cardsWidth}}\">\n\t\t\t\t<div class=\"item-wrapper\">\n\t\t\t\t\t<div class=\"item-img mb-3\">\n\t\t\t\t\t\t<a href=\"https://sites.google.com/site/pgvarth/home\" target=\"_blank\"><img src=\"@PROJECT_PATH@/assets/images/varth-600x600.jpg\" alt title data-slide-to=\"1\" data-bs-slide-to=\"1\"></a>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"item-content align-left\" mbr-if=\"showCardTitle || showCardSubtitle || showText || showButtons\">\n\t\t\t\t\t\t<h5 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".item-title\" mbr-if=\"showCardTitle\"><b>Petros Varthalitis&nbsp;</b></h5>\n\t\t\t\t\t\t<h6 class=\"item-subtitle mbr-fonts-style mb-3\" mbr-theme-style=\"display-7\" data-app-selector=\".item-subtitle\" mbr-if=\"showCardSubtitle\">Project Manager</h6>\n\t\t\t\t\t\t<p class=\"mbr-text mbr-fonts-style mt-3\" mbr-if=\"showText\" mbr-theme-style=\"display-4\" data-app-selector=\".mbr-text, .mbr-section-btn\">(Athens University of Economics and Business)<br></p>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"mbr-section-btn item-footer mt-2\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd\" mbr-buttons mbr-theme-style=\"display-7\">\n\t\t\t\t\t\t<a href class=\"btn item-btn btn-primary\" data-app-placeholder=\"Type Text\">Contact</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div class=\"item features-image col-12 col-md-6 col-lg-{{cardsWidth}}\">\n\t\t\t\t<div class=\"item-wrapper\">\n\t\t\t\t\t<div class=\"item-img mb-3\">\n\t\t\t\t\t\t<a href=\"https://www.slazarakis.com/\" target=\"_blank\"><img src=\"@PROJECT_PATH@/assets/images/spyridon-lazarakis-portrait-816x1253.jpg\" alt title data-slide-to=\"2\" data-bs-slide-to=\"2\"></a>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"item-content align-left\" mbr-if=\"showCardTitle || showCardSubtitle || showText || showButtons\">\n\t\t\t\t\t\t<h5 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".item-title\" mbr-if=\"showCardTitle\"><b>Spyridon Lazarakis</b></h5>\n\t\t\t\t\t\t<h6 class=\"item-subtitle mbr-fonts-style mb-3\" mbr-theme-style=\"display-7\" data-app-selector=\".item-subtitle\" mbr-if=\"showCardSubtitle\">UX Designer</h6>\n\t\t\t\t\t\t<p class=\"mbr-text mbr-fonts-style mt-3\" mbr-if=\"showText\" mbr-theme-style=\"display-4\" data-app-selector=\".mbr-text, .mbr-section-btn\">\n\t\t\t\t\t\t\t(Lancaster University)\n\t\t\t\t\t\t</p>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"mbr-section-btn item-footer mt-2\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd\" mbr-buttons mbr-theme-style=\"display-7\">\n\t\t\t\t\t\t<a href class=\"btn item-btn btn-primary\" data-app-placeholder=\"Type Text\">Contact</a>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t\n\t\t</div>\n\t</div>\n</section>",
